<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_grey_lig_dark"
    android:orientation="vertical"
    tools:context=".MactyTrasladoImagenAdicional">



    <!-- App Bar -->
    <include layout="@layout/item_nav_bar_back"
        android:id="@+id/back_activity"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"/>

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- Ubicación (oculta por defecto) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUbicacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/map_marker_icon"
                        app:tint="@android:color/holo_blue_light"
                        android:contentDescription="Ubicación" />

                    <TextView
                        android:id="@+id/tvUbicacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ubicacion..."
                        android:textSize="14sp"
                        android:textColor="@android:color/holo_blue_light"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ──────────────────────────────────────────── -->
            <!-- Detalle del Traslado                         -->
            <!-- ──────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/truck_icon"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="Traslado" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detalle del Traslado"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <include layout="@layout/item_traslado_detalle" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ──────────────────────────────────────────── -->
            <!-- Evidencia Fotográfica                        -->
            <!-- ──────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/camera_icon"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="Evidencia" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Evidencia Fotográfica"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Vista previa grande -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">



                        <ImageView
                            android:id="@+id/ivArchivoImagen"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/no_camara"
                            android:scaleType="centerCrop"
                            android:contentDescription="Vista previa de imagen" />

                        <ImageView
                            android:id="@+id/ivNoArchivoImagen"
                            android:layout_width="75dp"
                            android:layout_height="75dp"
                            android:layout_gravity="center_vertical|center_horizontal"
                            android:background="@drawable/camera_off_icon"
                            android:visibility="gone"
                            android:scaleType="centerCrop"
                            android:alpha="0.7"
                            android:contentDescription="Vista previa de imagen" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Botones foto / galería -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTomarFoto"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:icon="@drawable/camera_icon"
                            app:iconGravity="start"
                            app:iconPadding="6dp"
                            android:text="Tomar Foto" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSeleccionarImagen"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:icon="@drawable/image_multiple_icon"
                            app:iconGravity="start"
                            app:iconPadding="6dp"
                            android:text="Galería" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ──────────────────────────────────────────── -->
            <!-- Botón Principal: Enviar Imagen               -->
            <!-- ──────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrabar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                style="@style/Widget.Material3.Button"
                app:backgroundTint="@android:color/holo_green_light"
                app:iconGravity="start"
                app:iconPadding="8dp"
                app:cornerRadius="16dp"
                android:textSize="16sp"
                android:letterSpacing="0.02"
                android:text="Enviar Imagen" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>